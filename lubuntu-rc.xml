<!-- Fixes volume buttons on lenovo laptop in lubuntu -->
<!-- Use locate to find original file and overwrite corresponding parts -->


  <!-- Keybinding for Volume management -->
  <keybind key="XF86AudioRaiseVolume">
      <action name="Execute">
          <!-- <command>amixer -q sset Master 3%+ unmute</command> -->
	  <command>amixer -D pulse sset Master 5%+</command>
      </action>
  </keybind>
  <keybind key="XF86AudioLowerVolume">
      <action name="Execute">
          <!-- <command>amixer -q sset Master 3%- unmute</command> -->
	  <command>amixer -D pulse sset Master 5%-</command>
      </action>
  </keybind>
  <keybind key="XF86AudioMute">
      <action name="Execute">
          <!-- <command>amixer -q sset Master toggle</command> -->
	  <command>amixer -D pulse sset Master toggle</command>
      </action>
  </keybind>
